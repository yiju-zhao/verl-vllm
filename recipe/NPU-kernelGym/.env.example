# KernelGym configuration template.
# Copy to `.env` and fill in environment-specific values. `.env` is gitignored.

# Network
API_HOST=127.0.0.1            # IP/host the API server binds to
API_PORT=8002
API_WORKERS=4
API_RELOAD=false

# GPU / NPU
GPU_DEVICES=[0,1,2,3,4,5,6,7] # device ids this node exposes to the worker pool
GPU_MEMORY_LIMIT=16GB
NODE_ID=localhost.localdomain

# Redis
REDIS_HOST=localhost
REDIS_PORT=8001
REDIS_DB=0
REDIS_PASSWORD=               # set if your Redis requires auth
REDIS_KEY_PREFIX=kernelgym

# Worker pool
WORKER_POOL_SIZE=4
MAX_TASKS_PER_WORKER=100

# Defaults
DEFAULT_TOOLKIT=ascend_opt_gen_agent
DEFAULT_BACKEND_ADAPTER=kernelbench
DEFAULT_BACKEND=triton

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Metrics
ENABLE_METRICS=true
METRICS_PORT=8003

# Profiling
ENABLE_PROFILING=true

# Errors
VERBOSE_ERROR_TRACEBACK=true

# Result persistence
SAVE_EVAL_RESULTS=false
EVAL_RESULTS_PATH=logs/eval_results.jsonl
